{%- style -%}
  .wholesale-login-hero {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: {{ section.settings.min_height }}px;
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    background-color: {{ section.settings.background_color }};
    text-align: center;
  }

  @media screen and (min-width: 750px) {
    .wholesale-login-hero {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .wholesale-login-hero__inner {
    max-width: 600px;
    padding: 0 2rem;
  }

  .wholesale-login-hero__eyebrow {
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: {{ section.settings.eyebrow_color }};
    margin-bottom: 1.25rem;
  }

  .wholesale-login-hero__logo {
    margin-bottom: 2rem;
  }

  .wholesale-login-hero__logo img {
    max-width: {{ section.settings.logo_max_width }}px;
    height: auto;
  }

  .wholesale-login-hero__heading {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 400;
    line-height: 1.2;
    color: {{ section.settings.heading_color }};
    margin-bottom: 1.25rem;
  }

  .wholesale-login-hero__subtext {
    font-size: 1rem;
    line-height: 1.6;
    color: {{ section.settings.text_color }};
    margin-bottom: 2.5rem;
  }

  .wholesale-login-hero__cta {
    display: inline-block;
    padding: 1rem 2.5rem;
    background-color: {{ section.settings.button_background }};
    color: {{ section.settings.button_text_color }};
    font-size: 0.875rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    border: 1px solid {{ section.settings.button_background }};
    transition: background-color 0.2s ease, color 0.2s ease;
  }

  .wholesale-login-hero__cta:hover {
    background-color: transparent;
    color: {{ section.settings.button_background }};
  }

  .wholesale-login-hero__divider {
    width: 40px;
    height: 1px;
    background-color: {{ section.settings.text_color }};
    margin: 2rem auto;
    opacity: 0.3;
  }

  .wholesale-login-hero__note {
    font-size: 0.8rem;
    color: {{ section.settings.text_color }};
    opacity: 0.6;
  }
{%- endstyle -%}

<section class="wholesale-login-hero">
  <div class="wholesale-login-hero__inner">

    {%- if section.settings.eyebrow != blank -%}
      <p class="wholesale-login-hero__eyebrow">{{ section.settings.eyebrow }}</p>
    {%- endif -%}

    {%- if section.settings.logo != blank -%}
      <div class="wholesale-login-hero__logo">
        <img
          src="{{ section.settings.logo | image_url: width: section.settings.logo_max_width | times: 2 }}"
          alt="{{ section.settings.logo.alt | default: shop.name }}"
          width="{{ section.settings.logo_max_width }}"
          loading="eager"
        >
      </div>
    {%- else -%}
      <div class="wholesale-login-hero__logo">
        <span style="font-size: 1.5rem; letter-spacing: 0.15em; text-transform: uppercase; color: {{ section.settings.heading_color }};">
          {{ shop.name }}
        </span>
      </div>
    {%- endif -%}

    {%- if section.settings.heading != blank -%}
      <h1 class="wholesale-login-hero__heading">{{ section.settings.heading }}</h1>
    {%- endif -%}

    {%- if section.settings.subtext != blank -%}
      <p class="wholesale-login-hero__subtext">{{ section.settings.subtext }}</p>
    {%- endif -%}

    <a href="{{ routes.account_login_url }}" class="wholesale-login-hero__cta">
      {{ section.settings.button_label | default: 'Access Wholesale Account' }}
    </a>

    {%- if section.settings.show_note and section.settings.note != blank -%}
      <div class="wholesale-login-hero__divider"></div>
      <p class="wholesale-login-hero__note">{{ section.settings.note }}</p>
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "Wholesale Login Hero",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Branding"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image"
    },
    {
      "type": "range",
      "id": "logo_max_width",
      "min": 80,
      "max": 400,
      "step": 10,
      "unit": "px",
      "label": "Logo max width",
      "default": 180
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Wholesale Portal"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Welcome to Tadashi Shoji Wholesale"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "Exclusively for approved wholesale buyers. Sign in with your account credentials to access pricing, catalogs, and order tools."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Access Wholesale Account"
    },
    {
      "type": "checkbox",
      "id": "show_note",
      "label": "Show note below button",
      "default": true
    },
    {
      "type": "text",
      "id": "note",
      "label": "Note text",
      "default": "Don't have access? Contact your sales representative to request an account."
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "eyebrow_color",
      "label": "Eyebrow color",
      "default": "#999999"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Body text color",
      "default": "#4a4a4a"
    },
    {
      "type": "color",
      "id": "button_background",
      "label": "Button background color",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "min_height",
      "min": 300,
      "max": 900,
      "step": 50,
      "unit": "px",
      "label": "Minimum section height",
      "default": 600
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "Wholesale Login Hero"
    }
  ]
}
{% endschema %}
